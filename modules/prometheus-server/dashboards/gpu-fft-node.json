{
  "id": null,
  "uid": "gpu-fft-node",
  "title": "GPU - FFT Node",
  "tags": [
    "gpu",
    "nvidia",
    "prometheus"
  ],
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 0,
  "refresh": "5s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "uuid",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "effpfi5egefwgf"
        },
        "definition": "label_values(nvidia_smi_utilization_gpu_ratio{instance=\"fft:9835\"}, uuid)",
        "query": {
          "query": "label_values(nvidia_smi_utilization_gpu_ratio{instance=\"fft:9835\"}, uuid)",
          "refId": "VarUuid"
        },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "GPU Util %",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effpfi5egefwgf"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * avg(nvidia_smi_utilization_gpu_ratio{instance=\"fft:9835\",uuid=~\"$uuid\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "VRAM Used %",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effpfi5egefwgf"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * avg(nvidia_smi_memory_used_bytes{instance=\"fft:9835\",uuid=~\"$uuid\"}) / avg(nvidia_smi_memory_total_bytes{instance=\"fft:9835\",uuid=~\"$uuid\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      }
    },
