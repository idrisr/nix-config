      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(node_load1{node=\"router\"})",
          "legendFormat": "1m"
