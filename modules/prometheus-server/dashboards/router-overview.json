{
  "id": null,
  "uid": "router-overview",
  "title": "Router Overview",
  "tags": ["router", "node-exporter"],
  "timezone": "",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "Target Up",
      "datasource": {
        "type": "prometheus",
        "uid": "effpfi5egefwgf"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 38
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{node=\"router\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Uptime",
      "datasource": {
        "type": "prometheus",
        "uid": "effpfi5egefwgf"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 38
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(node_time_seconds{node=\"router\"} - node_boot_time_seconds{node=\"router\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "CPU Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "effpfi5egefwgf"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 38
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",node=\"router\"}[5m])) * 100)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Memory Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "effpfi5egefwgf"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 38
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - ((max(node_memory_MemAvailable_bytes{node=\"router\"}) or (max(node_memory_MemFree_bytes{node=\"router\"}) + max(node_memory_Buffers_bytes{node=\"router\"}) + max(node_memory_Cached_bytes{node=\"router\"}) + max(node_memory_SReclaimable_bytes{node=\"router\"}) - max(node_memory_Shmem_bytes{node=\"router\"})) or max(node_memory_free_bytes{node=\"router\"})) / (max(node_memory_MemTotal_bytes{node=\"router\"}) or max(node_memory_total_bytes{node=\"router\"})))) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Usage %",
      "datasource": {
        "type": "prometheus",
        "uid": "effpfi5egefwgf"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",node=\"router\"}[$__rate_interval])) * 100)",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
