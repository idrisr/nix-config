      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "DNS Response Latency (p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "effpfi5egefwgf"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 44
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(coredns_dns_request_duration_seconds_bucket{instance=~\"192\\.168\\.8\\.1.*|router.*\"}[$__rate_interval])))",
          "legendFormat": "coredns p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(adguard_dns_query_duration_seconds_bucket{instance=~\"192\\.168\\.8\\.1.*|router.*\"}[$__rate_interval])))",
          "legendFormat": "adguard p95"
        },
        {
          "refId": "C",
          "expr": "avg_over_time(probe_duration_seconds{job=~\".*dns.*\",instance=~\"192\\.168\\.8\\.1.*|router.*\"}[5m])",
          "legendFormat": "probe avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
