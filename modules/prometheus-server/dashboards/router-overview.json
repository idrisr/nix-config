    {
      "type": "timeseries",
      "title": "Network Errors / Drops",
      "datasource": {
        "type": "prometheus",
        "uid": "effpfi5egefwgf"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 44
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (device) (rate(node_network_receive_errs_total{node=\"router\",device!~\"lo|ifb.*\"}[$__rate_interval]) + rate(node_network_transmit_errs_total{node=\"router\",device!~\"lo|ifb.*\"}[$__rate_interval]))",
          "legendFormat": "{{device}} errors/s"
        },
        {
          "refId": "B",
          "expr": "sum by (device) (rate(node_network_receive_drop_total{node=\"router\",device!~\"lo|ifb.*\"}[$__rate_interval]) + rate(node_network_transmit_drop_total{node=\"router\",device!~\"lo|ifb.*\"}[$__rate_interval]))",
